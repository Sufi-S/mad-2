{"ast":null,"code":"export default {\n  name: 'TreatmentHistory',\n  data() {\n    return {\n      treatments: [],\n      loading: false,\n      exporting: false,\n      exportModal: null\n    };\n  },\n  mounted() {\n    this.fetchTreatments();\n    this.exportModal = new bootstrap.Modal(this.$refs.exportModal);\n  },\n  methods: {\n    async fetchTreatments() {\n      this.loading = true;\n      try {\n        const response = await this.$api.getTreatmentHistory();\n        this.treatments = response.data;\n      } catch (error) {\n        console.error('Error fetching treatments:', error);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async exportCSV() {\n      this.exporting = true;\n      this.exportModal.show();\n      try {\n        // This would trigger the async job\n        // For now, we'll simulate with a timeout\n        await new Promise(resolve => setTimeout(resolve, 2000));\n\n        // In real implementation, you would:\n        // 1. Call API to start export job\n        // 2. Poll for completion\n        // 3. Download file when ready\n\n        this.exportModal.hide();\n        alert('Export completed! Your file will be downloaded shortly.');\n\n        // Simulate download\n        // window.open('/api/patient/export-csv', '_blank')\n      } catch (error) {\n        this.exportModal.hide();\n        alert('Error exporting data');\n      } finally {\n        this.exporting = false;\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString('en-US', {\n        year: 'numeric',\n        month: 'long',\n        day: 'numeric'\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","treatments","loading","exporting","exportModal","mounted","fetchTreatments","bootstrap","Modal","$refs","methods","response","$api","getTreatmentHistory","error","console","exportCSV","show","Promise","resolve","setTimeout","hide","alert","formatDate","date","Date","toLocaleDateString","year","month","day"],"sources":["src/components/patient/TreatmentHistory.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- Page Header -->\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n      <h2>\r\n        <i class=\"fas fa-history me-2\"></i>\r\n        Treatment History\r\n      </h2>\r\n      <button class=\"btn btn-primary\" @click=\"exportCSV\" :disabled=\"exporting\">\r\n        <span v-if=\"exporting\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n        <i v-else class=\"fas fa-file-csv me-2\"></i>\r\n        Export as CSV\r\n      </button>\r\n    </div>\r\n\r\n    <!-- Treatments List -->\r\n    <div class=\"card\">\r\n      <div class=\"card-body\">\r\n        <div v-if=\"loading\" class=\"text-center py-5\">\r\n          <div class=\"spinner-border mb-3\" role=\"status\">\r\n            <span class=\"visually-hidden\">Loading...</span>\r\n          </div>\r\n          <p class=\"text-muted\">Loading treatment history...</p>\r\n        </div>\r\n        \r\n        <div v-else-if=\"treatments.length === 0\" class=\"text-center text-muted py-5\">\r\n          <i class=\"fas fa-notes-medical fa-4x mb-3\"></i>\r\n          <h5>No Treatment Records Found</h5>\r\n          <p>Your treatment history will appear here after your first visit.</p>\r\n          <router-link to=\"/book-appointment\" class=\"btn btn-primary mt-3\">\r\n            <i class=\"fas fa-calendar-plus me-2\"></i>\r\n            Book Appointment\r\n          </router-link>\r\n        </div>\r\n        \r\n        <div v-else>\r\n          <div v-for=\"treatment in treatments\" :key=\"treatment.id\" class=\"card bg-dark mb-3\">\r\n            <div class=\"card-body\">\r\n              <div class=\"d-flex justify-content-between align-items-start mb-3\">\r\n                <div>\r\n                  <h5 class=\"card-title mb-1\">\r\n                    Dr. {{ treatment.doctor_name }}\r\n                    <small class=\"text-muted ms-2\">{{ treatment.doctor?.specialization || 'Doctor' }}</small>\r\n                  </h5>\r\n                  <p class=\"text-muted mb-0\">\r\n                    <i class=\"fas fa-calendar-alt me-2\"></i>\r\n                    {{ formatDate(treatment.created_at) }}\r\n                  </p>\r\n                </div>\r\n                <span class=\"badge bg-info\">Treatment #{{ treatment.id }}</span>\r\n              </div>\r\n              \r\n              <div class=\"row\">\r\n                <div class=\"col-md-6\">\r\n                  <div class=\"mb-3\">\r\n                    <strong class=\"text-white-50 d-block mb-2\">\r\n                      <i class=\"fas fa-stethoscope me-2\"></i>\r\n                      Diagnosis\r\n                    </strong>\r\n                    <p class=\"mb-0\">{{ treatment.diagnosis }}</p>\r\n                  </div>\r\n                </div>\r\n                \r\n                <div class=\"col-md-6\">\r\n                  <div class=\"mb-3\">\r\n                    <strong class=\"text-white-50 d-block mb-2\">\r\n                      <i class=\"fas fa-prescription me-2\"></i>\r\n                      Prescription\r\n                    </strong>\r\n                    <p class=\"mb-0\">{{ treatment.prescription || 'No prescription' }}</p>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              \r\n              <div v-if=\"treatment.notes\" class=\"mb-3\">\r\n                <strong class=\"text-white-50 d-block mb-2\">\r\n                  <i class=\"fas fa-notes-medical me-2\"></i>\r\n                  Additional Notes\r\n                </strong>\r\n                <p class=\"mb-0\">{{ treatment.notes }}</p>\r\n              </div>\r\n              \r\n              <div v-if=\"treatment.next_visit_date\" class=\"mt-3 pt-3 border-top border-secondary\">\r\n                <i class=\"fas fa-calendar-check me-2 text-success\"></i>\r\n                <span class=\"text-success\">Next Visit: {{ formatDate(treatment.next_visit_date) }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Export Status Modal -->\r\n    <div class=\"modal fade\" id=\"exportModal\" tabindex=\"-1\" ref=\"exportModal\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">\r\n              <i class=\"fas fa-file-export me-2\"></i>\r\n              Export in Progress\r\n            </h5>\r\n          </div>\r\n          <div class=\"modal-body text-center py-4\">\r\n            <div class=\"spinner-border mb-3\" role=\"status\">\r\n              <span class=\"visually-hidden\">Loading...</span>\r\n            </div>\r\n            <p>Your CSV file is being generated...</p>\r\n            <p class=\"text-muted small\">You will be notified when it's ready.</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'TreatmentHistory',\r\n  data() {\r\n    return {\r\n      treatments: [],\r\n      loading: false,\r\n      exporting: false,\r\n      exportModal: null\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchTreatments()\r\n    this.exportModal = new bootstrap.Modal(this.$refs.exportModal)\r\n  },\r\n  methods: {\r\n    async fetchTreatments() {\r\n      this.loading = true\r\n      try {\r\n        const response = await this.$api.getTreatmentHistory()\r\n        this.treatments = response.data\r\n      } catch (error) {\r\n        console.error('Error fetching treatments:', error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    \r\n    async exportCSV() {\r\n      this.exporting = true\r\n      this.exportModal.show()\r\n      \r\n      try {\r\n        // This would trigger the async job\r\n        // For now, we'll simulate with a timeout\r\n        await new Promise(resolve => setTimeout(resolve, 2000))\r\n        \r\n        // In real implementation, you would:\r\n        // 1. Call API to start export job\r\n        // 2. Poll for completion\r\n        // 3. Download file when ready\r\n        \r\n        this.exportModal.hide()\r\n        alert('Export completed! Your file will be downloaded shortly.')\r\n        \r\n        // Simulate download\r\n        // window.open('/api/patient/export-csv', '_blank')\r\n        \r\n      } catch (error) {\r\n        this.exportModal.hide()\r\n        alert('Error exporting data')\r\n      } finally {\r\n        this.exporting = false\r\n      }\r\n    },\r\n    \r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString('en-US', {\r\n        year: 'numeric',\r\n        month: 'long',\r\n        day: 'numeric'\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AAoHA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;MACAC,OAAA;MACAC,SAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,eAAA;IACA,KAAAF,WAAA,OAAAG,SAAA,CAAAC,KAAA,MAAAC,KAAA,CAAAL,WAAA;EACA;EACAM,OAAA;IACA,MAAAJ,gBAAA;MACA,KAAAJ,OAAA;MACA;QACA,MAAAS,QAAA,cAAAC,IAAA,CAAAC,mBAAA;QACA,KAAAZ,UAAA,GAAAU,QAAA,CAAAX,IAAA;MACA,SAAAc,KAAA;QACAC,OAAA,CAAAD,KAAA,+BAAAA,KAAA;MACA;QACA,KAAAZ,OAAA;MACA;IACA;IAEA,MAAAc,UAAA;MACA,KAAAb,SAAA;MACA,KAAAC,WAAA,CAAAa,IAAA;MAEA;QACA;QACA;QACA,UAAAC,OAAA,CAAAC,OAAA,IAAAC,UAAA,CAAAD,OAAA;;QAEA;QACA;QACA;QACA;;QAEA,KAAAf,WAAA,CAAAiB,IAAA;QACAC,KAAA;;QAEA;QACA;MAEA,SAAAR,KAAA;QACA,KAAAV,WAAA,CAAAiB,IAAA;QACAC,KAAA;MACA;QACA,KAAAnB,SAAA;MACA;IACA;IAEAoB,WAAAC,IAAA;MACA,WAAAC,IAAA,CAAAD,IAAA,EAAAE,kBAAA;QACAC,IAAA;QACAC,KAAA;QACAC,GAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}