{"ast":null,"code":"export default {\n  name: 'App',\n  data() {\n    return {\n      isLoggedIn: false,\n      userRole: null,\n      username: null\n    };\n  },\n  created() {\n    this.checkAuth();\n  },\n  methods: {\n    checkAuth() {\n      const token = localStorage.getItem('access_token');\n      const role = localStorage.getItem('user_role');\n      const user = localStorage.getItem('user');\n      this.isLoggedIn = !!token;\n      this.userRole = role;\n      if (user) {\n        const userData = JSON.parse(user);\n        this.username = userData.username;\n      }\n    },\n    handleAuthSuccess(userData) {\n      this.isLoggedIn = true;\n      this.userRole = userData.user.role;\n      this.username = userData.user.username;\n\n      // Redirect based on role\n      if (this.userRole === 'admin') {\n        this.$router.push('/admin/dashboard');\n      } else if (this.userRole === 'doctor') {\n        this.$router.push('/doctor/dashboard');\n      } else {\n        this.$router.push('/patient/dashboard');\n      }\n    },\n    async logout() {\n      try {\n        await this.$api.logout();\n      } finally {\n        localStorage.clear();\n        this.isLoggedIn = false;\n        this.userRole = null;\n        this.username = null;\n        this.$router.push('/login');\n      }\n    }\n  },\n  filters: {\n    capitalize(value) {\n      if (!value) return '';\n      return value.charAt(0).toUpperCase() + value.slice(1);\n    }\n  }\n};","map":{"version":3,"names":["name","data","isLoggedIn","userRole","username","created","checkAuth","methods","token","localStorage","getItem","role","user","userData","JSON","parse","handleAuthSuccess","$router","push","logout","$api","clear","filters","capitalize","value","charAt","toUpperCase","slice"],"sources":["src/App.vue"],"sourcesContent":["<template>\r\n  <div id=\"app\">\r\n    <!-- Navigation Bar -->\r\n    <nav class=\"navbar navbar-expand-lg navbar-dark\" v-if=\"isLoggedIn\">\r\n      <div class=\"container\">\r\n        <router-link class=\"navbar-brand\" to=\"/\">\r\n          <i class=\"fas fa-hospital me-2\"></i>\r\n          HMS\r\n        </router-link>\r\n        \r\n        <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarNav\">\r\n          <span class=\"navbar-toggler-icon\"></span>\r\n        </button>\r\n        \r\n        <div class=\"collapse navbar-collapse\" id=\"navbarNav\">\r\n          <ul class=\"navbar-nav ms-auto\">\r\n            <!-- Admin Navigation -->\r\n            <template v-if=\"userRole === 'admin'\">\r\n              <li class=\"nav-item\">\r\n                <router-link class=\"nav-link\" to=\"/admin/dashboard\">\r\n                  <i class=\"fas fa-tachometer-alt me-1\"></i> Dashboard\r\n                </router-link>\r\n              </li>\r\n            </template>\r\n\r\n            <!-- Doctor Navigation -->\r\n            <template v-if=\"userRole === 'doctor'\">\r\n              <li class=\"nav-item\">\r\n                <router-link class=\"nav-link\" to=\"/doctor/dashboard\">\r\n                  <i class=\"fas fa-tachometer-alt me-1\"></i> Dashboard\r\n                </router-link>\r\n              </li>\r\n            </template>\r\n\r\n            <!-- Patient Navigation -->\r\n            <template v-if=\"userRole === 'patient'\">\r\n              <li class=\"nav-item\">\r\n                <router-link class=\"nav-link\" to=\"/patient/dashboard\">\r\n                  <i class=\"fas fa-tachometer-alt me-1\"></i> Dashboard\r\n                </router-link>\r\n              </li>\r\n              <li class=\"nav-item\">\r\n                <router-link class=\"nav-link\" to=\"/doctors\">\r\n                  <i class=\"fas fa-user-md me-1\"></i> Find Doctors\r\n                </router-link>\r\n              </li>\r\n              <li class=\"nav-item\">\r\n                <router-link class=\"nav-link\" to=\"/book-appointment\">\r\n                  <i class=\"fas fa-calendar-plus me-1\"></i> Book Appointment\r\n                </router-link>\r\n              </li>\r\n              <li class=\"nav-item\">\r\n                <router-link class=\"nav-link\" to=\"/treatment-history\">\r\n                  <i class=\"fas fa-history me-1\"></i> My History\r\n                </router-link>\r\n              </li>\r\n            </template>\r\n\r\n            <!-- User Info & Logout -->\r\n            <li class=\"nav-item dropdown\">\r\n              <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"userDropdown\" role=\"button\" data-bs-toggle=\"dropdown\">\r\n                <i class=\"fas fa-user-circle me-1\"></i>\r\n                {{ username || 'User' }}\r\n              </a>\r\n              <ul class=\"dropdown-menu dropdown-menu-end\">\r\n                <li>\r\n                  <span class=\"dropdown-item-text text-muted\">\r\n                    Role: {{ userRole | capitalize }}\r\n                  </span>\r\n                </li>\r\n                <li><hr class=\"dropdown-divider\"></li>\r\n                <li>\r\n                  <a class=\"dropdown-item\" href=\"#\" @click.prevent=\"logout\">\r\n                    <i class=\"fas fa-sign-out-alt me-2\"></i> Logout\r\n                  </a>\r\n                </li>\r\n              </ul>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n      </div>\r\n    </nav>\r\n\r\n    <!-- Main Content -->\r\n    <div class=\"container mt-4\">\r\n      <router-view @auth-success=\"handleAuthSuccess\" />\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'App',\r\n  data() {\r\n    return {\r\n      isLoggedIn: false,\r\n      userRole: null,\r\n      username: null\r\n    }\r\n  },\r\n  created() {\r\n    this.checkAuth()\r\n  },\r\n  methods: {\r\n    checkAuth() {\r\n      const token = localStorage.getItem('access_token')\r\n      const role = localStorage.getItem('user_role')\r\n      const user = localStorage.getItem('user')\r\n      \r\n      this.isLoggedIn = !!token\r\n      this.userRole = role\r\n      \r\n      if (user) {\r\n        const userData = JSON.parse(user)\r\n        this.username = userData.username\r\n      }\r\n    },\r\n    handleAuthSuccess(userData) {\r\n      this.isLoggedIn = true\r\n      this.userRole = userData.user.role\r\n      this.username = userData.user.username\r\n      \r\n      // Redirect based on role\r\n      if (this.userRole === 'admin') {\r\n        this.$router.push('/admin/dashboard')\r\n      } else if (this.userRole === 'doctor') {\r\n        this.$router.push('/doctor/dashboard')\r\n      } else {\r\n        this.$router.push('/patient/dashboard')\r\n      }\r\n    },\r\n    async logout() {\r\n      try {\r\n        await this.$api.logout()\r\n      } finally {\r\n        localStorage.clear()\r\n        this.isLoggedIn = false\r\n        this.userRole = null\r\n        this.username = null\r\n        this.$router.push('/login')\r\n      }\r\n    }\r\n  },\r\n  filters: {\r\n    capitalize(value) {\r\n      if (!value) return ''\r\n      return value.charAt(0).toUpperCase() + value.slice(1)\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style>\r\n@import './assets/styles.css';\r\n</style>"],"mappings":"AA2FA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;MACAC,QAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAD,UAAA;MACA,MAAAE,KAAA,GAAAC,YAAA,CAAAC,OAAA;MACA,MAAAC,IAAA,GAAAF,YAAA,CAAAC,OAAA;MACA,MAAAE,IAAA,GAAAH,YAAA,CAAAC,OAAA;MAEA,KAAAR,UAAA,KAAAM,KAAA;MACA,KAAAL,QAAA,GAAAQ,IAAA;MAEA,IAAAC,IAAA;QACA,MAAAC,QAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAH,IAAA;QACA,KAAAR,QAAA,GAAAS,QAAA,CAAAT,QAAA;MACA;IACA;IACAY,kBAAAH,QAAA;MACA,KAAAX,UAAA;MACA,KAAAC,QAAA,GAAAU,QAAA,CAAAD,IAAA,CAAAD,IAAA;MACA,KAAAP,QAAA,GAAAS,QAAA,CAAAD,IAAA,CAAAR,QAAA;;MAEA;MACA,SAAAD,QAAA;QACA,KAAAc,OAAA,CAAAC,IAAA;MACA,gBAAAf,QAAA;QACA,KAAAc,OAAA,CAAAC,IAAA;MACA;QACA,KAAAD,OAAA,CAAAC,IAAA;MACA;IACA;IACA,MAAAC,OAAA;MACA;QACA,WAAAC,IAAA,CAAAD,MAAA;MACA;QACAV,YAAA,CAAAY,KAAA;Q