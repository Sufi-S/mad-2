{"ast":null,"code":"export default {\n  name: 'AdminDashboard',\n  data() {\n    return {\n      stats: {},\n      appointments: [],\n      searchQuery: '',\n      searchType: 'all',\n      searchResults: null,\n      showSearch: false,\n      loading: false,\n      deleteTarget: null\n    };\n  },\n  mounted() {\n    this.fetchData();\n    this.deleteModal = new bootstrap.Modal(this.$refs.deleteModal);\n  },\n  methods: {\n    async fetchData() {\n      this.loading = true;\n      try {\n        const [dashboard, appointments] = await Promise.all([this.$api.getAdminDashboard(), this.$api.getAllAppointments()]);\n        this.stats = dashboard.data;\n        this.appointments = appointments.data.slice(0, 10); // Last 10 appointments\n      } catch (error) {\n        console.error('Error fetching data:', error);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async refreshData() {\n      await this.fetchData();\n    },\n    async performSearch() {\n      if (!this.searchQuery.trim()) {\n        this.searchResults = null;\n        return;\n      }\n      try {\n        const response = await this.$api.search(this.searchQuery, this.searchType);\n        this.searchResults = response.data;\n      } catch (error) {\n        console.error('Search error:', error);\n      }\n    },\n    confirmDeletePatient(patient) {\n      this.deleteTarget = {\n        type: 'patient',\n        id: patient.id,\n        name: patient.name\n      };\n      this.deleteModal.show();\n    },\n    async deleteConfirmed() {\n      try {\n        if (this.deleteTarget.type === 'patient') {\n          await this.$api.deletePatient(this.deleteTarget.id);\n        }\n        this.deleteModal.hide();\n        this.searchResults = null;\n        this.searchQuery = '';\n        await this.fetchData();\n      } catch (error) {\n        alert('Error deleting user');\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    exportReport() {\n      // TODO: Implement report export\n      alert('Report export feature coming soon!');\n    }\n  }\n};","map":{"version":3,"names":["name","data","stats","appointments","searchQuery","searchType","searchResults","showSearch","loading","deleteTarget","mounted","fetchData","deleteModal","bootstrap","Modal","$refs","methods","dashboard","Promise","all","$api","getAdminDashboard","getAllAppointments","slice","error","console","refreshData","performSearch","trim","response","search","confirmDeletePatient","patient","type","id","show","deleteConfirmed","deletePatient","hide","alert","formatDate","date","Date","toLocaleDateString","exportReport"],"sources":["src/components/admin/AdminDashboard.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- Page Header -->\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n      <h2>\r\n        <i class=\"fas fa-tachometer-alt me-2\"></i>\r\n        Admin Dashboard\r\n      </h2>\r\n      <div>\r\n        <button class=\"btn btn-primary me-2\" @click=\"refreshData\">\r\n          <i class=\"fas fa-sync-alt me-2\"></i>\r\n          Refresh\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Stats Cards -->\r\n    <div class=\"row mb-4\">\r\n      <div class=\"col-md-3 mb-3\">\r\n        <div class=\"stat-card\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"fas fa-user-md\"></i>\r\n          </div>\r\n          <div class=\"stat-value\">{{ stats.total_doctors || 0 }}</div>\r\n          <div class=\"stat-label\">Total Doctors</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-md-3 mb-3\">\r\n        <div class=\"stat-card\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"fas fa-users\"></i>\r\n          </div>\r\n          <div class=\"stat-value\">{{ stats.total_patients || 0 }}</div>\r\n          <div class=\"stat-label\">Total Patients</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-md-3 mb-3\">\r\n        <div class=\"stat-card\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"fas fa-calendar-check\"></i>\r\n          </div>\r\n          <div class=\"stat-value\">{{ stats.total_appointments || 0 }}</div>\r\n          <div class=\"stat-label\">Total Appointments</div>\r\n        </div>\r\n      </div>\r\n      <div class=\"col-md-3 mb-3\">\r\n        <div class=\"stat-card\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"fas fa-chart-line\"></i>\r\n          </div>\r\n          <div class=\"stat-value\">{{ stats.appointment_stats?.completed || 0 }}</div>\r\n          <div class=\"stat-label\">Completed</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Quick Actions -->\r\n    <div class=\"row mb-4\">\r\n      <div class=\"col-12\">\r\n        <div class=\"card\">\r\n          <div class=\"card-header\">\r\n            <i class=\"fas fa-bolt me-2\"></i>\r\n            Quick Actions\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <div class=\"row\">\r\n              <div class=\"col-md-3 mb-2\">\r\n                <router-link to=\"/admin/doctors\" class=\"btn btn-secondary w-100\">\r\n                  <i class=\"fas fa-user-md me-2\"></i>\r\n                  Manage Doctors\r\n                </router-link>\r\n              </div>\r\n              <div class=\"col-md-3 mb-2\">\r\n                <button class=\"btn btn-secondary w-100\" @click=\"showSearch = !showSearch\">\r\n                  <i class=\"fas fa-search me-2\"></i>\r\n                  Search\r\n                </button>\r\n              </div>\r\n              <div class=\"col-md-3 mb-2\">\r\n                <button class=\"btn btn-secondary w-100\" @click=\"exportReport\">\r\n                  <i class=\"fas fa-file-export me-2\"></i>\r\n                  Export Report\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Search Section -->\r\n    <div v-if=\"showSearch\" class=\"card mb-4\">\r\n      <div class=\"card-header\">\r\n        <i class=\"fas fa-search me-2\"></i>\r\n        Search Patients / Doctors\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div class=\"row\">\r\n          <div class=\"col-md-6\">\r\n            <div class=\"input-group\">\r\n              <input \r\n                type=\"text\" \r\n                class=\"form-control\" \r\n                placeholder=\"Search by name, specialization, phone...\" \r\n                v-model=\"searchQuery\"\r\n                @keyup.enter=\"performSearch\"\r\n              >\r\n              <button class=\"btn btn-primary\" type=\"button\" @click=\"performSearch\">\r\n                <i class=\"fas fa-search\"></i>\r\n              </button>\r\n            </div>\r\n          </div>\r\n          <div class=\"col-md-3\">\r\n            <select class=\"form-select\" v-model=\"searchType\">\r\n              <option value=\"all\">All</option>\r\n              <option value=\"doctors\">Doctors Only</option>\r\n              <option value=\"patients\">Patients Only</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- Search Results -->\r\n        <div v-if=\"searchResults\" class=\"mt-4\">\r\n          <div v-if=\"searchResults.doctors?.length\" class=\"mb-4\">\r\n            <h6 class=\"text-white-50 mb-3\">\r\n              <i class=\"fas fa-user-md me-2\"></i>\r\n              Doctors ({{ searchResults.doctors.length }})\r\n            </h6>\r\n            <div class=\"table-responsive\">\r\n              <table class=\"table table-hover\">\r\n                <thead>\r\n                  <tr>\r\n                    <th>Name</th>\r\n                    <th>Specialization</th>\r\n                    <th>Experience</th>\r\n                    <th>Fee</th>\r\n                    <th>Actions</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  <tr v-for=\"doctor in searchResults.doctors\" :key=\"doctor.id\">\r\n                    <td>{{ doctor.name }}</td>\r\n                    <td>{{ doctor.specialization }}</td>\r\n                    <td>{{ doctor.experience_years || 0 }} years</td>\r\n                    <td>${{ doctor.consultation_fee || 0 }}</td>\r\n                    <td>\r\n                      <router-link :to=\"'/admin/doctors?edit=' + doctor.id\" class=\"btn btn-sm btn-primary me-1\">\r\n                        <i class=\"fas fa-edit\"></i>\r\n                      </router-link>\r\n                    </td>\r\n                  </tr>\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n          \r\n          <div v-if=\"searchResults.patients?.length\">\r\n            <h6 class=\"text-white-50 mb-3\">\r\n              <i class=\"fas fa-users me-2\"></i>\r\n              Patients ({{ searchResults.patients.length }})\r\n            </h6>\r\n            <div class=\"table-responsive\">\r\n              <table class=\"table table-hover\">\r\n                <thead>\r\n                  <tr>\r\n                    <th>Name</th>\r\n                    <th>Phone</th>\r\n                    <th>Blood Group</th>\r\n                    <th>Actions</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  <tr v-for=\"patient in searchResults.patients\" :key=\"patient.id\">\r\n                    <td>{{ patient.name }}</td>\r\n                    <td>{{ patient.phone }}</td>\r\n                    <td>{{ patient.blood_group || 'N/A' }}</td>\r\n                    <td>\r\n                      <button class=\"btn btn-sm btn-danger\" @click=\"confirmDeletePatient(patient)\">\r\n                        <i class=\"fas fa-trash\"></i>\r\n                      </button>\r\n                    </td>\r\n                  </tr>\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n\r\n          <div v-if=\"!searchResults.doctors?.length && !searchResults.patients?.length\" class=\"text-center text-muted py-4\">\r\n            <i class=\"fas fa-search fa-3x mb-3\"></i>\r\n            <p>No results found</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Recent Appointments -->\r\n    <div class=\"card\">\r\n      <div class=\"card-header\">\r\n        <i class=\"fas fa-calendar-alt me-2\"></i>\r\n        Recent Appointments\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div v-if=\"loading\" class=\"text-center py-4\">\r\n          <div class=\"spinner-border\" role=\"status\">\r\n            <span class=\"visually-hidden\">Loading...</span>\r\n          </div>\r\n        </div>\r\n        \r\n        <div v-else-if=\"appointments.length === 0\" class=\"text-center text-muted py-4\">\r\n          <i class=\"fas fa-calendar-times fa-3x mb-3\"></i>\r\n          <p>No appointments found</p>\r\n        </div>\r\n        \r\n        <div v-else class=\"table-responsive\">\r\n          <table class=\"table table-hover\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Patient</th>\r\n                <th>Doctor</th>\r\n                <th>Date</th>\r\n                <th>Time</th>\r\n                <th>Status</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"apt in appointments\" :key=\"apt.id\">\r\n                <td>#{{ apt.id }}</td>\r\n                <td>{{ apt.patient_name }}</td>\r\n                <td>{{ apt.doctor_name }}</td>\r\n                <td>{{ formatDate(apt.appointment_date) }}</td>\r\n                <td>{{ apt.appointment_time }}</td>\r\n                <td>\r\n                  <span class=\"badge\" :class=\"{\r\n                    'bg-success': apt.status === 'completed',\r\n                    'bg-warning': apt.status === 'booked',\r\n                    'bg-danger': apt.status === 'cancelled'\r\n                  }\">\r\n                    {{ apt.status }}\r\n                  </span>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Delete Confirmation Modal -->\r\n    <div class=\"modal fade\" id=\"deleteModal\" tabindex=\"-1\" ref=\"deleteModal\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">\r\n              <i class=\"fas fa-exclamation-triangle text-danger me-2\"></i>\r\n              Confirm Delete\r\n            </h5>\r\n            <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            Are you sure you want to delete {{ deleteTarget?.name }}?\r\n            <p class=\"text-muted mt-2\">\r\n              <small>This will deactivate the user account. This action can be undone by reactivating.</small>\r\n            </p>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancel</button>\r\n            <button type=\"button\" class=\"btn btn-danger\" @click=\"deleteConfirmed\">\r\n              <i class=\"fas fa-trash me-2\"></i>\r\n              Delete\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'AdminDashboard',\r\n  data() {\r\n    return {\r\n      stats: {},\r\n      appointments: [],\r\n      searchQuery: '',\r\n      searchType: 'all',\r\n      searchResults: null,\r\n      showSearch: false,\r\n      loading: false,\r\n      deleteTarget: null\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchData()\r\n    this.deleteModal = new bootstrap.Modal(this.$refs.deleteModal)\r\n  },\r\n  methods: {\r\n    async fetchData() {\r\n      this.loading = true\r\n      try {\r\n        const [dashboard, appointments] = await Promise.all([\r\n          this.$api.getAdminDashboard(),\r\n          this.$api.getAllAppointments()\r\n        ])\r\n        \r\n        this.stats = dashboard.data\r\n        this.appointments = appointments.data.slice(0, 10) // Last 10 appointments\r\n        \r\n      } catch (error) {\r\n        console.error('Error fetching data:', error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    \r\n    async refreshData() {\r\n      await this.fetchData()\r\n    },\r\n    \r\n    async performSearch() {\r\n      if (!this.searchQuery.trim()) {\r\n        this.searchResults = null\r\n        return\r\n      }\r\n      \r\n      try {\r\n        const response = await this.$api.search(this.searchQuery, this.searchType)\r\n        this.searchResults = response.data\r\n      } catch (error) {\r\n        console.error('Search error:', error)\r\n      }\r\n    },\r\n    \r\n    confirmDeletePatient(patient) {\r\n      this.deleteTarget = { type: 'patient', id: patient.id, name: patient.name }\r\n      this.deleteModal.show()\r\n    },\r\n    \r\n    async deleteConfirmed() {\r\n      try {\r\n        if (this.deleteTarget.type === 'patient') {\r\n          await this.$api.deletePatient(this.deleteTarget.id)\r\n        }\r\n        \r\n        this.deleteModal.hide()\r\n        this.searchResults = null\r\n        this.searchQuery = ''\r\n        await this.fetchData()\r\n        \r\n      } catch (error) {\r\n        alert('Error deleting user')\r\n      }\r\n    },\r\n    \r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    \r\n    exportReport() {\r\n      // TODO: Implement report export\r\n      alert('Report export feature coming soon!')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AAuRA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,KAAA;MACAC,YAAA;MACAC,WAAA;MACAC,UAAA;MACAC,aAAA;MACAC,UAAA;MACAC,OAAA;MACAC,YAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;IACA,KAAAC,WAAA,OAAAC,SAAA,CAAAC,KAAA,MAAAC,KAAA,CAAAH,WAAA;EACA;EACAI,OAAA;IACA,MAAAL,UAAA;MACA,KAAAH,OAAA;MACA;QACA,OAAAS,SAAA,EAAAd,YAAA,UAAAe,OAAA,CAAAC,GAAA,EACA,KAAAC,IAAA,CAAAC,iBAAA,IACA,KAAAD,IAAA,CAAAE,kBAAA,GACA;QAEA,KAAApB,KAAA,GAAAe,SAAA,CAAAhB,IAAA;QACA,KAAAE,YAAA,GAAAA,YAAA,CAAAF,IAAA,CAAAsB,KAAA;MAEA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,yBAAAA,KAAA;MACA;QACA,KAAAhB,OAAA;MACA;IACA;IAEA,MAAAkB,YAAA;MACA,WAAAf,SAAA;IACA;IAEA,MAAAgB,cAAA;MACA,UAAAvB,WAAA,CAAAwB,IAAA;QACA,KAAAtB,aAAA;QACA;MACA;MAEA;QACA,MAAAuB,QAAA,cAAAT,IAAA,CAAAU,MAAA,MAAA1B,WAAA,OAAAC,UAAA;QACA,KAAAC,aAAA,GAAAuB,QAAA,CAAA5B,IAAA;MACA,SAAAuB,KAAA;QACAC,OAAA,CAAAD,KAAA,kBAAAA,KAAA;MACA;IACA;IAEAO,qBAAAC,OAAA;MACA,KAAAvB,YAAA;QAAAwB,IAAA;QAAAC,EAAA,EAAAF,OAAA,CAAAE,EAAA;QAAAlC,IAAA,EAAAgC,OAAA,CAAAhC;MAAA;MACA,KAAAY,WAAA,CAAAuB,IAAA;IACA;IAEA,MAAAC,gBAAA;MACA;QACA,SAAA3B,YAAA,CAAAwB,IAAA;UACA,WAAAb,IAAA,CAAAiB,aAAA,MAAA5B,YAAA,CAAAyB,EAAA;QACA;QAEA,KAAAtB,WAAA,CAAA0B,IAAA;QACA,KAAAhC,aAAA;QACA,KAAAF,WAAA;QACA,WAAAO,SAAA;MAEA,SAAAa,KAAA;QACAe,KAAA;MACA;IACA;IAEAC,WAAAC,IAAA;MACA,WAAAC,IAAA,CAAAD,IAAA,EAAAE,kBAAA;IACA;IAEAC,aAAA;MACA;MACAL,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}