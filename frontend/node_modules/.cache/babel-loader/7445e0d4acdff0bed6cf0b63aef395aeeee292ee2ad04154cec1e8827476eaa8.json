{"ast":null,"code":"export default {\n  name: 'PatientDashboard',\n  data() {\n    return {\n      departments: [],\n      upcomingAppointments: [],\n      pastAppointments: [],\n      profile: {},\n      saving: false,\n      showProfileModal: false\n    };\n  },\n  mounted() {\n    this.fetchDashboard();\n    this.fetchProfile();\n    this.profileModal = new bootstrap.Modal(this.$refs.profileModal);\n  },\n  watch: {\n    showProfileModal(val) {\n      if (val) {\n        this.profileModal.show();\n      } else {\n        this.profileModal.hide();\n      }\n    }\n  },\n  methods: {\n    async fetchDashboard() {\n      try {\n        const response = await this.$api.getPatientDashboard();\n        const data = response.data;\n        this.departments = data.departments || [];\n        this.upcomingAppointments = data.upcoming_appointments || [];\n        this.pastAppointments = data.past_appointments || [];\n      } catch (error) {\n        console.error('Error fetching dashboard:', error);\n      }\n    },\n    fetchProfile() {\n      const savedProfile = localStorage.getItem('profile');\n      if (savedProfile) {\n        this.profile = JSON.parse(savedProfile);\n      }\n    },\n    async updateProfile() {\n      this.saving = true;\n      try {\n        const response = await this.$api.updatePatientProfile(this.profile);\n        localStorage.setItem('profile', JSON.stringify(response.data.profile));\n        this.showProfileModal = false;\n        alert('Profile updated successfully!');\n      } catch (error) {\n        alert(error.response?.data?.error || 'Error updating profile');\n      } finally {\n        this.saving = false;\n      }\n    },\n    async cancelAppointment(appointment) {\n      if (confirm(`Cancel appointment with Dr. ${appointment.doctor_name}?`)) {\n        try {\n          await this.$api.cancelAppointment(appointment.id);\n          await this.fetchDashboard();\n        } catch (error) {\n          alert('Error cancelling appointment');\n        }\n      }\n    },\n    viewTreatment(appointment) {\n      this.$router.push(`/treatment-history?appointment=${appointment.id}`);\n    },\n    searchBySpecialization(specialization) {\n      this.$router.push(`/book-appointment?specialization=${specialization}`);\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    }\n  }\n};","map":{"version":3,"names":["name","data","departments","upcomingAppointments","pastAppointments","profile","saving","showProfileModal","mounted","fetchDashboard","fetchProfile","profileModal","bootstrap","Modal","$refs","watch","val","show","hide","methods","response","$api","getPatientDashboard","upcoming_appointments","past_appointments","error","console","savedProfile","localStorage","getItem","JSON","parse","updateProfile","updatePatientProfile","setItem","stringify","alert","cancelAppointment","appointment","confirm","doctor_name","id","viewTreatment","$router","push","searchBySpecialization","specialization","formatDate","date","Date","toLocaleDateString"],"sources":["src/components/patient/PatientDashboard.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- Page Header -->\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n      <h2>\r\n        <i class=\"fas fa-tachometer-alt me-2\"></i>\r\n        Patient Dashboard\r\n      </h2>\r\n      <button class=\"btn btn-primary\" @click=\"showProfileModal = true\">\r\n        <i class=\"fas fa-user-edit me-2\"></i>\r\n        Edit Profile\r\n      </button>\r\n    </div>\r\n\r\n    <!-- Departments/Specializations -->\r\n    <div class=\"card mb-4\">\r\n      <div class=\"card-header\">\r\n        <i class=\"fas fa-stethoscope me-2\"></i>\r\n        Available Specializations\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div class=\"row\">\r\n          <div class=\"col-md-3 mb-3\" v-for=\"dept in departments\" :key=\"dept.id\">\r\n            <div class=\"card bg-dark h-100\" @click=\"searchBySpecialization(dept.name)\" style=\"cursor: pointer;\">\r\n              <div class=\"card-body text-center\">\r\n                <i class=\"fas fa-heartbeat fa-3x mb-3 text-white-50\"></i>\r\n                <h6 class=\"card-title\">{{ dept.name }}</h6>\r\n                <p class=\"card-text small text-muted\">{{ dept.description }}</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Upcoming Appointments -->\r\n    <div class=\"card mb-4\">\r\n      <div class=\"card-header\">\r\n        <i class=\"fas fa-calendar-alt me-2\"></i>\r\n        Upcoming Appointments\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div v-if=\"upcomingAppointments.length === 0\" class=\"text-center text-muted py-4\">\r\n          <i class=\"fas fa-calendar-plus fa-3x mb-3\"></i>\r\n          <p>No upcoming appointments</p>\r\n          <router-link to=\"/book-appointment\" class=\"btn btn-primary\">\r\n            <i class=\"fas fa-plus me-2\"></i>\r\n            Book Appointment\r\n          </router-link>\r\n        </div>\r\n        \r\n        <div v-else class=\"table-responsive\">\r\n          <table class=\"table table-hover\">\r\n            <thead>\r\n              <tr>\r\n                <th>Doctor</th>\r\n                <th>Specialization</th>\r\n                <th>Date</th>\r\n                <th>Time</th>\r\n                <th>Status</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"apt in upcomingAppointments\" :key=\"apt.id\">\r\n                <td>{{ apt.doctor_name }}</td>\r\n                <td>{{ apt.doctor?.specialization || 'N/A' }}</td>\r\n                <td>{{ formatDate(apt.appointment_date) }}</td>\r\n                <td>{{ apt.appointment_time }}</td>\r\n                <td>\r\n                  <span class=\"badge bg-warning\">{{ apt.status }}</span>\r\n                </td>\r\n                <td>\r\n                  <button class=\"btn btn-sm btn-danger\" @click=\"cancelAppointment(apt)\">\r\n                    <i class=\"fas fa-times me-1\"></i>\r\n                    Cancel\r\n                  </button>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Past Appointments -->\r\n    <div class=\"card\">\r\n      <div class=\"card-header\">\r\n        <i class=\"fas fa-history me-2\"></i>\r\n        Past Appointments\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div v-if=\"pastAppointments.length === 0\" class=\"text-center text-muted py-4\">\r\n          <i class=\"fas fa-calendar-times fa-3x mb-3\"></i>\r\n          <p>No past appointments</p>\r\n        </div>\r\n        \r\n        <div v-else class=\"table-responsive\">\r\n          <table class=\"table table-hover\">\r\n            <thead>\r\n              <tr>\r\n                <th>Date</th>\r\n                <th>Doctor</th>\r\n                <th>Specialization</th>\r\n                <th>Diagnosis</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"apt in pastAppointments\" :key=\"apt.id\">\r\n                <td>{{ formatDate(apt.appointment_date) }}</td>\r\n                <td>{{ apt.doctor_name }}</td>\r\n                <td>{{ apt.doctor?.specialization || 'N/A' }}</td>\r\n                <td>{{ apt.treatment?.diagnosis || 'N/A' }}</td>\r\n                <td>\r\n                  <button class=\"btn btn-sm btn-info\" @click=\"viewTreatment(apt)\">\r\n                    <i class=\"fas fa-eye me-1\"></i>\r\n                    View Details\r\n                  </button>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Edit Profile Modal -->\r\n    <div class=\"modal fade\" id=\"profileModal\" tabindex=\"-1\" ref=\"profileModal\">\r\n      <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n          <div class=\"modal-header\">\r\n            <h5 class=\"modal-title\">\r\n              <i class=\"fas fa-user-edit me-2\"></i>\r\n              Edit Profile\r\n            </h5>\r\n            <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\"></button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <form @submit.prevent=\"updateProfile\">\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Full Name</label>\r\n                <input type=\"text\" class=\"form-control\" v-model=\"profile.name\" required>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Phone Number</label>\r\n                <input type=\"tel\" class=\"form-control\" v-model=\"profile.phone\" required>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Date of Birth</label>\r\n                <input type=\"date\" class=\"form-control\" v-model=\"profile.date_of_birth\">\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Gender</label>\r\n                <select class=\"form-select\" v-model=\"profile.gender\">\r\n                  <option value=\"\">Select Gender</option>\r\n                  <option value=\"male\">Male</option>\r\n                  <option value=\"female\">Female</option>\r\n                  <option value=\"other\">Other</option>\r\n                </select>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Blood Group</label>\r\n                <select class=\"form-select\" v-model=\"profile.blood_group\">\r\n                  <option value=\"\">Select Blood Group</option>\r\n                  <option value=\"A+\">A+</option>\r\n                  <option value=\"A-\">A-</option>\r\n                  <option value=\"B+\">B+</option>\r\n                  <option value=\"B-\">B-</option>\r\n                  <option value=\"O+\">O+</option>\r\n                  <option value=\"O-\">O-</option>\r\n                  <option value=\"AB+\">AB+</option>\r\n                  <option value=\"AB-\">AB-</option>\r\n                </select>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Emergency Contact</label>\r\n                <input type=\"tel\" class=\"form-control\" v-model=\"profile.emergency_contact\">\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">Address</label>\r\n                <textarea class=\"form-control\" rows=\"2\" v-model=\"profile.address\"></textarea>\r\n              </div>\r\n            </form>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancel</button>\r\n            <button type=\"button\" class=\"btn btn-primary\" @click=\"updateProfile\" :disabled=\"saving\">\r\n              <span v-if=\"saving\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n              <i v-else class=\"fas fa-save me-2\"></i>\r\n              Save Changes\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'PatientDashboard',\r\n  data() {\r\n    return {\r\n      departments: [],\r\n      upcomingAppointments: [],\r\n      pastAppointments: [],\r\n      profile: {},\r\n      saving: false,\r\n      showProfileModal: false\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchDashboard()\r\n    this.fetchProfile()\r\n    this.profileModal = new bootstrap.Modal(this.$refs.profileModal)\r\n  },\r\n  watch: {\r\n    showProfileModal(val) {\r\n      if (val) {\r\n        this.profileModal.show()\r\n      } else {\r\n        this.profileModal.hide()\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    async fetchDashboard() {\r\n      try {\r\n        const response = await this.$api.getPatientDashboard()\r\n        const data = response.data\r\n        \r\n        this.departments = data.departments || []\r\n        this.upcomingAppointments = data.upcoming_appointments || []\r\n        this.pastAppointments = data.past_appointments || []\r\n        \r\n      } catch (error) {\r\n        console.error('Error fetching dashboard:', error)\r\n      }\r\n    },\r\n    \r\n    fetchProfile() {\r\n      const savedProfile = localStorage.getItem('profile')\r\n      if (savedProfile) {\r\n        this.profile = JSON.parse(savedProfile)\r\n      }\r\n    },\r\n    \r\n    async updateProfile() {\r\n      this.saving = true\r\n      try {\r\n        const response = await this.$api.updatePatientProfile(this.profile)\r\n        localStorage.setItem('profile', JSON.stringify(response.data.profile))\r\n        this.showProfileModal = false\r\n        alert('Profile updated successfully!')\r\n      } catch (error) {\r\n        alert(error.response?.data?.error || 'Error updating profile')\r\n      } finally {\r\n        this.saving = false\r\n      }\r\n    },\r\n    \r\n    async cancelAppointment(appointment) {\r\n      if (confirm(`Cancel appointment with Dr. ${appointment.doctor_name}?`)) {\r\n        try {\r\n          await this.$api.cancelAppointment(appointment.id)\r\n          await this.fetchDashboard()\r\n        } catch (error) {\r\n          alert('Error cancelling appointment')\r\n        }\r\n      }\r\n    },\r\n    \r\n    viewTreatment(appointment) {\r\n      this.$router.push(`/treatment-history?appointment=${appointment.id}`)\r\n    },\r\n    \r\n    searchBySpecialization(specialization) {\r\n      this.$router.push(`/book-appointment?specialization=${specialization}`)\r\n    },\r\n    \r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AA8MA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MACAC,oBAAA;MACAC,gBAAA;MACAC,OAAA;MACAC,MAAA;MACAC,gBAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,cAAA;IACA,KAAAC,YAAA;IACA,KAAAC,YAAA,OAAAC,SAAA,CAAAC,KAAA,MAAAC,KAAA,CAAAH,YAAA;EACA;EACAI,KAAA;IACAR,iBAAAS,GAAA;MACA,IAAAA,GAAA;QACA,KAAAL,YAAA,CAAAM,IAAA;MACA;QACA,KAAAN,YAAA,CAAAO,IAAA;MACA;IACA;EACA;EACAC,OAAA;IACA,MAAAV,eAAA;MACA;QACA,MAAAW,QAAA,cAAAC,IAAA,CAAAC,mBAAA;QACA,MAAArB,IAAA,GAAAmB,QAAA,CAAAnB,IAAA;QAEA,KAAAC,WAAA,GAAAD,IAAA,CAAAC,WAAA;QACA,KAAAC,oBAAA,GAAAF,IAAA,CAAAsB,qBAAA;QACA,KAAAnB,gBAAA,GAAAH,IAAA,CAAAuB,iBAAA;MAEA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,8BAAAA,KAAA;MACA;IACA;IAEAf,aAAA;MACA,MAAAiB,YAAA,GAAAC,YAAA,CAAAC,OAAA;MACA,IAAAF,YAAA;QACA,KAAAtB,OAAA,GAAAyB,IAAA,CAAAC,KAAA,CAAAJ,YAAA;MACA;IACA;IAEA,MAAAK,cAAA;MACA,KAAA1B,MAAA;MACA;QACA,MAAAc,QAAA,cAAAC,IAAA,CAAAY,oBAAA,MAAA5B,OAAA;QACAuB,YAAA,CAAAM,OAAA,YAAAJ,IAAA,CAAAK,SAAA,CAAAf,QAAA,CAAAnB,IAAA,CAAAI,OAAA;QACA,KAAAE,gBAAA;QACA6B,KAAA;MACA,SAAAX,KAAA;QACAW,KAAA,CAAAX,KAAA,CAAAL,QAAA,EAAAnB,IAAA,EAAAwB,KAAA;MACA;QACA,KAAAnB,MAAA;MACA;IACA;IAEA,MAAA+B,kBAAAC,WAAA;MACA,IAAAC,OAAA,gCAAAD,WAAA,CAAAE,WAAA;QACA;UACA,WAAAnB,IAAA,CAAAgB,iBAAA,CAAAC,WAAA,CAAAG,EAAA;UACA,WAAAhC,cAAA;QACA,SAAAgB,KAAA;UACAW,KAAA;QACA;MACA;IACA;IAEAM,cAAAJ,WAAA;MACA,KAAAK,OAAA,CAAAC,IAAA,mCAAAN,WAAA,CAAAG,EAAA;IACA;IAEAI,uBAAAC,cAAA;MACA,KAAAH,OAAA,CAAAC,IAAA,qCAAAE,cAAA;IACA;IAEAC,WAAAC,IAAA;MACA,WAAAC,IAAA,CAAAD,IAAA,EAAAE,kBAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}