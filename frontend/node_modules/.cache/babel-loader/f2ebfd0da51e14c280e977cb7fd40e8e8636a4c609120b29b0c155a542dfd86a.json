{"ast":null,"code":"export default {\n  name: 'Register',\n  data() {\n    return {\n      formData: {\n        username: '',\n        email: '',\n        password: '',\n        name: '',\n        phone: '',\n        date_of_birth: '',\n        gender: '',\n        address: '',\n        blood_group: '',\n        emergency_contact: ''\n      },\n      confirmPassword: '',\n      loading: false,\n      error: '',\n      success: ''\n    };\n  },\n  methods: {\n    async handleRegister() {\n      // Validate passwords match\n      if (this.formData.password !== this.confirmPassword) {\n        this.error = 'Passwords do not match';\n        return;\n      }\n      this.loading = true;\n      this.error = '';\n      this.success = '';\n      try {\n        await this.$api.register(this.formData);\n        this.success = 'Registration successful! Redirecting to login...';\n\n        // Clear form\n        this.formData = {\n          username: '',\n          email: '',\n          password: '',\n          name: '',\n          phone: '',\n          date_of_birth: '',\n          gender: '',\n          address: '',\n          blood_group: '',\n          emergency_contact: ''\n        };\n        this.confirmPassword = '';\n\n        // Redirect to login after 2 seconds\n        setTimeout(() => {\n          this.$router.push('/login');\n        }, 2000);\n      } catch (error) {\n        this.error = error.response?.data?.error || 'Registration failed. Please try again.';\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","formData","username","email","password","phone","date_of_birth","gender","address","blood_group","emergency_contact","confirmPassword","loading","error","success","methods","handleRegister","$api","register","setTimeout","$router","push","response"],"sources":["src/components/auth/Register.vue"],"sourcesContent":["<template>\r\n  <div class=\"row justify-content-center\">\r\n    <div class=\"col-md-8 col-lg-6\">\r\n      <div class=\"card\">\r\n        <div class=\"card-header\">\r\n          <h4 class=\"mb-0\">\r\n            <i class=\"fas fa-user-plus me-2\"></i>\r\n            Patient Registration\r\n          </h4>\r\n        </div>\r\n        <div class=\"card-body\">\r\n          <!-- Success/Error Alerts -->\r\n          <div v-if=\"success\" class=\"alert alert-success\">\r\n            <i class=\"fas fa-check-circle me-2\"></i>\r\n            {{ success }}\r\n          </div>\r\n          \r\n          <div v-if=\"error\" class=\"alert alert-danger\">\r\n            <i class=\"fas fa-exclamation-circle me-2\"></i>\r\n            {{ error }}\r\n          </div>\r\n\r\n          <form @submit.prevent=\"handleRegister\">\r\n            <!-- Account Information -->\r\n            <h5 class=\"text-white-50 mb-3\">\r\n              <i class=\"fas fa-id-card me-2\"></i>\r\n              Account Information\r\n            </h5>\r\n            \r\n            <div class=\"row\">\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Username *</label>\r\n                <input \r\n                  type=\"text\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.username\"\r\n                  required\r\n                  placeholder=\"Choose username\"\r\n                >\r\n              </div>\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Email *</label>\r\n                <input \r\n                  type=\"email\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.email\"\r\n                  required\r\n                  placeholder=\"Enter email\"\r\n                >\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"row\">\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Password *</label>\r\n                <input \r\n                  type=\"password\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.password\"\r\n                  required\r\n                  minlength=\"6\"\r\n                  placeholder=\"Min 6 characters\"\r\n                >\r\n              </div>\r\n              <div class=\"col-md-6 mb-4\">\r\n                <label class=\"form-label\">Confirm Password *</label>\r\n                <input \r\n                  type=\"password\" \r\n                  class=\"form-control\" \r\n                  v-model=\"confirmPassword\"\r\n                  required\r\n                  placeholder=\"Re-enter password\"\r\n                >\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Personal Information -->\r\n            <h5 class=\"text-white-50 mb-3\">\r\n              <i class=\"fas fa-user me-2\"></i>\r\n              Personal Information\r\n            </h5>\r\n\r\n            <div class=\"row\">\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Full Name *</label>\r\n                <input \r\n                  type=\"text\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.name\"\r\n                  required\r\n                  placeholder=\"Enter full name\"\r\n                >\r\n              </div>\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Phone Number *</label>\r\n                <input \r\n                  type=\"tel\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.phone\"\r\n                  required\r\n                  placeholder=\"Enter phone number\"\r\n                >\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"row\">\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Date of Birth</label>\r\n                <input \r\n                  type=\"date\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.date_of_birth\"\r\n                >\r\n              </div>\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Gender</label>\r\n                <select class=\"form-select\" v-model=\"formData.gender\">\r\n                  <option value=\"\">Select Gender</option>\r\n                  <option value=\"male\">Male</option>\r\n                  <option value=\"female\">Female</option>\r\n                  <option value=\"other\">Other</option>\r\n                </select>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"row\">\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Blood Group</label>\r\n                <select class=\"form-select\" v-model=\"formData.blood_group\">\r\n                  <option value=\"\">Select Blood Group</option>\r\n                  <option value=\"A+\">A+</option>\r\n                  <option value=\"A-\">A-</option>\r\n                  <option value=\"B+\">B+</option>\r\n                  <option value=\"B-\">B-</option>\r\n                  <option value=\"O+\">O+</option>\r\n                  <option value=\"O-\">O-</option>\r\n                  <option value=\"AB+\">AB+</option>\r\n                  <option value=\"AB-\">AB-</option>\r\n                </select>\r\n              </div>\r\n              <div class=\"col-md-6 mb-3\">\r\n                <label class=\"form-label\">Emergency Contact</label>\r\n                <input \r\n                  type=\"tel\" \r\n                  class=\"form-control\" \r\n                  v-model=\"formData.emergency_contact\"\r\n                  placeholder=\"Emergency phone number\"\r\n                >\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"mb-4\">\r\n              <label class=\"form-label\">Address</label>\r\n              <textarea \r\n                class=\"form-control\" \r\n                rows=\"2\" \r\n                v-model=\"formData.address\"\r\n                placeholder=\"Enter full address\"\r\n              ></textarea>\r\n            </div>\r\n\r\n            <div class=\"d-flex gap-2\">\r\n              <button type=\"submit\" class=\"btn btn-primary flex-grow-1\" :disabled=\"loading\">\r\n                <span v-if=\"loading\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n                <i v-else class=\"fas fa-user-plus me-2\"></i>\r\n                {{ loading ? 'Registering...' : 'Register' }}\r\n              </button>\r\n              <router-link to=\"/login\" class=\"btn btn-secondary\">\r\n                <i class=\"fas fa-arrow-left me-2\"></i>\r\n                Back\r\n              </router-link>\r\n            </div>\r\n          </form>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'Register',\r\n  data() {\r\n    return {\r\n      formData: {\r\n        username: '',\r\n        email: '',\r\n        password: '',\r\n        name: '',\r\n        phone: '',\r\n        date_of_birth: '',\r\n        gender: '',\r\n        address: '',\r\n        blood_group: '',\r\n        emergency_contact: ''\r\n      },\r\n      confirmPassword: '',\r\n      loading: false,\r\n      error: '',\r\n      success: ''\r\n    }\r\n  },\r\n  methods: {\r\n    async handleRegister() {\r\n      // Validate passwords match\r\n      if (this.formData.password !== this.confirmPassword) {\r\n        this.error = 'Passwords do not match'\r\n        return\r\n      }\r\n      \r\n      this.loading = true\r\n      this.error = ''\r\n      this.success = ''\r\n      \r\n      try {\r\n        await this.$api.register(this.formData)\r\n        this.success = 'Registration successful! Redirecting to login...'\r\n        \r\n        // Clear form\r\n        this.formData = {\r\n          username: '', email: '', password: '', name: '',\r\n          phone: '', date_of_birth: '', gender: '',\r\n          address: '', blood_group: '', emergency_contact: ''\r\n        }\r\n        this.confirmPassword = ''\r\n        \r\n        // Redirect to login after 2 seconds\r\n        setTimeout(() => {\r\n          this.$router.push('/login')\r\n        }, 2000)\r\n        \r\n      } catch (error) {\r\n        this.error = error.response?.data?.error || 'Registration failed. Please try again.'\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AAoLA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;QACAC,QAAA;QACAC,KAAA;QACAC,QAAA;QACAL,IAAA;QACAM,KAAA;QACAC,aAAA;QACAC,MAAA;QACAC,OAAA;QACAC,WAAA;QACAC,iBAAA;MACA;MACAC,eAAA;MACAC,OAAA;MACAC,KAAA;MACAC,OAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,eAAA;MACA;MACA,SAAAf,QAAA,CAAAG,QAAA,UAAAO,eAAA;QACA,KAAAE,KAAA;QACA;MACA;MAEA,KAAAD,OAAA;MACA,KAAAC,KAAA;MACA,KAAAC,OAAA;MAEA;QACA,WAAAG,IAAA,CAAAC,QAAA,MAAAjB,QAAA;QACA,KAAAa,OAAA;;QAEA;QACA,KAAAb,QAAA;UACAC,QAAA;UAAAC,KAAA;UAAAC,QAAA;UAAAL,IAAA;UACAM,KAAA;UAAAC,aAAA;UAAAC,MAAA;UACAC,OAAA;UAAAC,WAAA;UAAAC,iBAAA;QACA;QACA,KAAAC,eAAA;;QAEA;QACAQ,UAAA;UACA,KAAAC,OAAA,CAAAC,IAAA;QACA;MAEA,SAAAR,KAAA;QACA,KAAAA,KAAA,GAAAA,KAAA,CAAAS,QAAA,EAAAtB,IAAA,EAAAa,KAAA;MACA;QACA,KAAAD,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}