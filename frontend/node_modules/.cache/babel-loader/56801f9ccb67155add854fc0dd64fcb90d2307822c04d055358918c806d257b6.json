{"ast":null,"code":"export default {\n  name: 'Login',\n  data() {\n    return {\n      credentials: {\n        username: '',\n        password: ''\n      },\n      loading: false,\n      error: ''\n    };\n  },\n  methods: {\n    async handleLogin() {\n      this.loading = true;\n      this.error = '';\n      try {\n        const response = await this.$api.login(this.credentials);\n        const userData = response.data;\n\n        // Store tokens and user data\n        localStorage.setItem('access_token', userData.access_token);\n        localStorage.setItem('refresh_token', userData.refresh_token);\n        localStorage.setItem('user_role', userData.user.role);\n        localStorage.setItem('user', JSON.stringify(userData.user));\n        if (userData.profile) {\n          localStorage.setItem('profile', JSON.stringify(userData.profile));\n        }\n\n        // Emit success event to App.vue\n        this.$emit('auth-success', userData);\n      } catch (error) {\n        this.error = error.response?.data?.error || 'Login failed. Please try again.';\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","data","credentials","username","password","loading","error","methods","handleLogin","response","$api","login","userData","localStorage","setItem","access_token","refresh_token","user","role","JSON","stringify","profile","$emit"],"sources":["src/components/auth/Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"row justify-content-center\">\r\n    <div class=\"col-md-6 col-lg-4\">\r\n      <div class=\"card\">\r\n        <div class=\"card-header\">\r\n          <h4 class=\"mb-0\">\r\n            <i class=\"fas fa-sign-in-alt me-2\"></i>\r\n            Login\r\n          </h4>\r\n        </div>\r\n        <div class=\"card-body\">\r\n          <!-- Error Alert -->\r\n          <div v-if=\"error\" class=\"alert alert-danger\">\r\n            <i class=\"fas fa-exclamation-circle me-2\"></i>\r\n            {{ error }}\r\n          </div>\r\n\r\n          <!-- Login Form -->\r\n          <form @submit.prevent=\"handleLogin\">\r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">\r\n                <i class=\"fas fa-user me-2\"></i>\r\n                Username\r\n              </label>\r\n              <input \r\n                type=\"text\" \r\n                class=\"form-control\" \r\n                v-model=\"credentials.username\"\r\n                required\r\n                placeholder=\"Enter username\"\r\n              >\r\n            </div>\r\n\r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">\r\n                <i class=\"fas fa-lock me-2\"></i>\r\n                Password\r\n              </label>\r\n              <input \r\n                type=\"password\" \r\n                class=\"form-control\" \r\n                v-model=\"credentials.password\"\r\n                required\r\n                placeholder=\"Enter password\"\r\n              >\r\n            </div>\r\n\r\n            <button type=\"submit\" class=\"btn btn-primary w-100\" :disabled=\"loading\">\r\n              <span v-if=\"loading\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n              <i v-else class=\"fas fa-sign-in-alt me-2\"></i>\r\n              {{ loading ? 'Logging in...' : 'Login' }}\r\n            </button>\r\n          </form>\r\n\r\n          <hr class=\"my-4\">\r\n\r\n          <div class=\"text-center\">\r\n            <p class=\"text-muted mb-2\">Don't have an account?</p>\r\n            <router-link to=\"/register\" class=\"btn btn-secondary w-100\">\r\n              <i class=\"fas fa-user-plus me-2\"></i>\r\n              Register as Patient\r\n            </router-link>\r\n          </div>\r\n\r\n          <!-- Demo Credentials -->\r\n          <div class=\"mt-4 p-3 bg-dark rounded\">\r\n            <small class=\"text-muted d-block mb-2\">\r\n              <i class=\"fas fa-info-circle me-1\"></i>\r\n              Demo Credentials:\r\n            </small>\r\n            <div class=\"row g-2\">\r\n              <div class=\"col-6\">\r\n                <div class=\"p-2 bg-black rounded\">\r\n                  <strong class=\"text-white-50 d-block\">Admin</strong>\r\n                  <small class=\"text-muted\">admin / admin123</small>\r\n                </div>\r\n              </div>\r\n              <div class=\"col-6\">\r\n                <div class=\"p-2 bg-black rounded\">\r\n                  <strong class=\"text-white-50 d-block\">Doctor</strong>\r\n                  <small class=\"text-muted\">doctor / doctor123</small>\r\n                </div>\r\n              </div>\r\n              <div class=\"col-12 mt-2\">\r\n                <div class=\"p-2 bg-black rounded\">\r\n                  <strong class=\"text-white-50 d-block\">Patient</strong>\r\n                  <small class=\"text-muted\">patient / patient123</small>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'Login',\r\n  data() {\r\n    return {\r\n      credentials: {\r\n        username: '',\r\n        password: ''\r\n      },\r\n      loading: false,\r\n      error: ''\r\n    }\r\n  },\r\n  methods: {\r\n    async handleLogin() {\r\n      this.loading = true\r\n      this.error = ''\r\n      \r\n      try {\r\n        const response = await this.$api.login(this.credentials)\r\n        const userData = response.data\r\n        \r\n        // Store tokens and user data\r\n        localStorage.setItem('access_token', userData.access_token)\r\n        localStorage.setItem('refresh_token', userData.refresh_token)\r\n        localStorage.setItem('user_role', userData.user.role)\r\n        localStorage.setItem('user', JSON.stringify(userData.user))\r\n        \r\n        if (userData.profile) {\r\n          localStorage.setItem('profile', JSON.stringify(userData.profile))\r\n        }\r\n        \r\n        // Emit success event to App.vue\r\n        this.$emit('auth-success', userData)\r\n        \r\n      } catch (error) {\r\n        this.error = error.response?.data?.error || 'Login failed. Please try again.'\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AAkGA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;QACAC,QAAA;QACAC,QAAA;MACA;MACAC,OAAA;MACAC,KAAA;IACA;EACA;EACAC,OAAA;IACA,MAAAC,YAAA;MACA,KAAAH,OAAA;MACA,KAAAC,KAAA;MAEA;QACA,MAAAG,QAAA,cAAAC,IAAA,CAAAC,KAAA,MAAAT,WAAA;QACA,MAAAU,QAAA,GAAAH,QAAA,CAAAR,IAAA;;QAEA;QACAY,YAAA,CAAAC,OAAA,iBAAAF,QAAA,CAAAG,YAAA;QACAF,YAAA,CAAAC,OAAA,kBAAAF,QAAA,CAAAI,aAAA;QACAH,YAAA,CAAAC,OAAA,cAAAF,QAAA,CAAAK,IAAA,CAAAC,IAAA;QACAL,YAAA,CAAAC,OAAA,SAAAK,IAAA,CAAAC,SAAA,CAAAR,QAAA,CAAAK,IAAA;QAEA,IAAAL,QAAA,CAAAS,OAAA;UACAR,YAAA,CAAAC,OAAA,YAAAK,IAAA,CAAAC,SAAA,CAAAR,QAAA,CAAAS,OAAA;QACA;;QAEA;QACA,KAAAC,KAAA,iBAAAV,QAAA;MAEA,SAAAN,KAAA;QACA,KAAAA,KAAA,GAAAA,KAAA,CAAAG,QAAA,EAAAR,IAAA,EAAAK,KAAA;MACA;QACA,KAAAD,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}