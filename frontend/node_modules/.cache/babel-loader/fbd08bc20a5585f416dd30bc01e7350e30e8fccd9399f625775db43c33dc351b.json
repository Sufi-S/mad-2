{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nexport default {\n  name: 'BookAppointment',\n  data() {\n    return {\n      departments: [],\n      doctors: [],\n      selectedDoctor: null,\n      searchFilters: {\n        specialization: '',\n        name: ''\n      },\n      loading: false,\n      booking: false,\n      availableDates: [],\n      selectedDate: null,\n      availableSlots: [],\n      selectedTime: null,\n      symptoms: '',\n      bookedSlots: {}\n    };\n  },\n  created() {\n    this.fetchDepartments();\n\n    // Check URL params\n    const specialization = this.$route.query.specialization;\n    if (specialization) {\n      this.searchFilters.specialization = specialization;\n      this.searchDoctors();\n    }\n  },\n  methods: {\n    async fetchDepartments() {\n      try {\n        const response = await this.$api.getDepartments();\n        this.departments = response.data;\n      } catch (error) {\n        console.error('Error fetching departments:', error);\n      }\n    },\n    async searchDoctors() {\n      this.loading = true;\n      try {\n        const response = await this.$api.searchDoctors(this.searchFilters.specialization, this.searchFilters.name);\n        this.doctors = response.data;\n      } catch (error) {\n        console.error('Error searching doctors:', error);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async selectDoctor(doctor) {\n      this.selectedDoctor = doctor;\n      await this.fetchAvailability();\n      this.generateAvailableDates();\n    },\n    async fetchAvailability() {\n      try {\n        const response = await this.$api.getDoctorAvailability(this.selectedDoctor.id);\n        this.bookedSlots = response.data.booked_slots || {};\n\n        // Generate next 7 days\n        this.generateAvailableDates();\n      } catch (error) {\n        console.error('Error fetching availability:', error);\n      }\n    },\n    generateAvailableDates() {\n      const dates = [];\n      const today = new Date();\n      for (let i = 0; i < 7; i++) {\n        const date = new Date(today);\n        date.setDate(today.getDate() + i);\n        const dateStr = date.toISOString().split('T')[0];\n        dates.push(dateStr);\n      }\n      this.availableDates = dates;\n    },\n    selectDate(date) {\n      this.selectedDate = date;\n      this.selectedTime = null;\n\n      // Get available slots for this date\n      const dayName = new Date(date).toLocaleDateString('en-US', {\n        weekday: 'long'\n      }).toLowerCase();\n      const doctorAvailability = this.selectedDoctor.availability || {};\n\n      // Get doctor's available slots for this day\n      const availableForDay = doctorAvailability[dayName] || [];\n\n      // Remove booked slots\n      const bookedForDate = this.bookedSlots[date] || [];\n      this.availableSlots = availableForDay.filter(slot => !bookedForDate.includes(slot));\n    },\n    selectTime(time) {\n      this.selectedTime = time;\n    },\n    async bookAppointment() {\n      this.booking = true;\n      try {\n        await this.$api.bookAppointment({\n          doctor_id: this.selectedDoctor.id,\n          date: this.selectedDate,\n          time: this.selectedTime,\n          symptoms: this.symptoms\n        });\n        alert('Appointment booked successfully!');\n        this.$router.push('/patient/dashboard');\n      } catch (error) {\n        alert(error.response?.data?.error || 'Error booking appointment');\n      } finally {\n        this.booking = false;\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString('en-US', {\n        weekday: 'short',\n        month: 'short',\n        day: 'numeric'\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","departments","doctors","selectedDoctor","searchFilters","specialization","loading","booking","availableDates","selectedDate","availableSlots","selectedTime","symptoms","bookedSlots","created","fetchDepartments","$route","query","searchDoctors","methods","response","$api","getDepartments","error","console","selectDoctor","doctor","fetchAvailability","generateAvailableDates","getDoctorAvailability","id","booked_slots","dates","today","Date","i","date","setDate","getDate","dateStr","toISOString","split","push","selectDate","dayName","toLocaleDateString","weekday","toLowerCase","doctorAvailability","availability","availableForDay","bookedForDate","filter","slot","includes","selectTime","time","bookAppointment","doctor_id","alert","$router","formatDate","month","day"],"sources":["src/components/patient/BookAppointment.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- Page Header -->\r\n    <div class=\"d-flex justify-content-between align-items-center mb-4\">\r\n      <h2>\r\n        <i class=\"fas fa-calendar-plus me-2\"></i>\r\n        {{ selectedDoctor ? 'Book Appointment' : 'Find Doctors' }}\r\n      </h2>\r\n    </div>\r\n\r\n    <!-- Search Section -->\r\n    <div class=\"card mb-4\" v-if=\"!selectedDoctor\">\r\n      <div class=\"card-header\">\r\n        <i class=\"fas fa-search me-2\"></i>\r\n        Search Doctors\r\n      </div>\r\n      <div class=\"card-body\">\r\n        <div class=\"row\">\r\n          <div class=\"col-md-5\">\r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">Specialization</label>\r\n              <select class=\"form-select\" v-model=\"searchFilters.specialization\">\r\n                <option value=\"\">All Specializations</option>\r\n                <option v-for=\"dept in departments\" :key=\"dept.id\" :value=\"dept.name\">\r\n                  {{ dept.name }}\r\n                </option>\r\n              </select>\r\n            </div>\r\n          </div>\r\n          <div class=\"col-md-5\">\r\n            <div class=\"form-group\">\r\n              <label class=\"form-label\">Doctor Name</label>\r\n              <input \r\n                type=\"text\" \r\n                class=\"form-control\" \r\n                v-model=\"searchFilters.name\"\r\n                placeholder=\"Search by doctor name\"\r\n              >\r\n            </div>\r\n          </div>\r\n          <div class=\"col-md-2 d-flex align-items-end\">\r\n            <button class=\"btn btn-primary w-100\" @click=\"searchDoctors\">\r\n              <i class=\"fas fa-search me-2\"></i>\r\n              Search\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Doctors List -->\r\n    <div class=\"row\" v-if=\"!selectedDoctor\">\r\n      <div class=\"col-12\">\r\n        <div class=\"card\">\r\n          <div class=\"card-header\">\r\n            <i class=\"fas fa-user-md me-2\"></i>\r\n            Available Doctors\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <div v-if=\"loading\" class=\"text-center py-4\">\r\n              <div class=\"spinner-border\" role=\"status\">\r\n                <span class=\"visually-hidden\">Loading...</span>\r\n              </div>\r\n            </div>\r\n            \r\n            <div v-else-if=\"doctors.length === 0\" class=\"text-center text-muted py-4\">\r\n              <i class=\"fas fa-user-md fa-3x mb-3\"></i>\r\n              <p>No doctors found</p>\r\n            </div>\r\n            \r\n            <div v-else class=\"row\">\r\n              <div v-for=\"doctor in doctors\" :key=\"doctor.id\" class=\"col-md-6 mb-4\">\r\n                <div class=\"card bg-dark h-100\">\r\n                  <div class=\"card-body\">\r\n                    <div class=\"d-flex align-items-center mb-3\">\r\n                      <div class=\"flex-shrink-0\">\r\n                        <i class=\"fas fa-user-circle fa-3x text-white-50\"></i>\r\n                      </div>\r\n                      <div class=\"flex-grow-1 ms-3\">\r\n                        <h5 class=\"card-title mb-1\">{{ doctor.name }}</h5>\r\n                        <p class=\"text-muted mb-0\">{{ doctor.specialization }}</p>\r\n                      </div>\r\n                    </div>\r\n                    \r\n                    <div class=\"mb-3\">\r\n                      <small class=\"text-white-50 d-block\">\r\n                        <i class=\"fas fa-graduation-cap me-2\"></i>\r\n                        {{ doctor.qualification || 'Qualification N/A' }}\r\n                      </small>\r\n                      <small class=\"text-white-50 d-block\">\r\n                        <i class=\"fas fa-briefcase me-2\"></i>\r\n                        {{ doctor.experience_years || 0 }} years experience\r\n                      </small>\r\n                      <small class=\"text-white-50 d-block\">\r\n                        <i class=\"fas fa-dollar-sign me-2\"></i>\r\n                        Consultation Fee: ${{ doctor.consultation_fee || 0 }}\r\n                      </small>\r\n                    </div>\r\n                    \r\n                    <button class=\"btn btn-primary w-100\" @click=\"selectDoctor(doctor)\">\r\n                      <i class=\"fas fa-calendar-plus me-2\"></i>\r\n                      Book Appointment\r\n                    </button>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Booking Form -->\r\n    <div v-else class=\"row justify-content-center\">\r\n      <div class=\"col-md-8\">\r\n        <div class=\"card\">\r\n          <div class=\"card-header\">\r\n            <h5 class=\"mb-0\">\r\n              <i class=\"fas fa-calendar-check me-2\"></i>\r\n              Book Appointment with Dr. {{ selectedDoctor.name }}\r\n            </h5>\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <!-- Doctor Info -->\r\n            <div class=\"mb-4 p-3 bg-dark rounded\">\r\n              <div class=\"row\">\r\n                <div class=\"col-md-6\">\r\n                  <p class=\"mb-1\">\r\n                    <strong>Specialization:</strong> {{ selectedDoctor.specialization }}\r\n                  </p>\r\n                  <p class=\"mb-1\">\r\n                    <strong>Experience:</strong> {{ selectedDoctor.experience_years || 0 }} years\r\n                  </p>\r\n                </div>\r\n                <div class=\"col-md-6\">\r\n                  <p class=\"mb-1\">\r\n                    <strong>Qualification:</strong> {{ selectedDoctor.qualification || 'N/A' }}\r\n                  </p>\r\n                  <p class=\"mb-1\">\r\n                    <strong>Fee:</strong> ${{ selectedDoctor.consultation_fee || 0 }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Date Selection -->\r\n            <div class=\"form-group mb-4\">\r\n              <label class=\"form-label\">Select Date</label>\r\n              <div class=\"row\">\r\n                <div class=\"col-md-4 mb-2\" v-for=\"date in availableDates\" :key=\"date\">\r\n                  <button \r\n                    class=\"btn w-100\" \r\n                    :class=\"selectedDate === date ? 'btn-primary' : 'btn-secondary'\"\r\n                    @click=\"selectDate(date)\"\r\n                  >\r\n                    {{ formatDate(date) }}\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Time Slots -->\r\n            <div v-if=\"selectedDate\" class=\"form-group mb-4\">\r\n              <label class=\"form-label\">Available Time Slots</label>\r\n              <div class=\"d-flex flex-wrap gap-2\">\r\n                <span \r\n                  v-for=\"slot in availableSlots\" \r\n                  :key=\"slot\"\r\n                  class=\"badge\"\r\n                  :class=\"selectedTime === slot ? 'bg-success' : 'bg-secondary'\"\r\n                  @click=\"selectTime(slot)\"\r\n                  style=\"cursor: pointer; padding: 0.75rem 1.5rem; font-size: 1rem;\"\r\n                >\r\n                  {{ slot }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Symptoms -->\r\n            <div v-if=\"selectedTime\" class=\"form-group mb-4\">\r\n              <label class=\"form-label\">Symptoms / Reason for Visit</label>\r\n              <textarea \r\n                class=\"form-control\" \r\n                rows=\"3\" \r\n                v-model=\"symptoms\"\r\n                placeholder=\"Describe your symptoms or reason for visit\"\r\n              ></textarea>\r\n            </div>\r\n\r\n            <!-- Actions -->\r\n            <div class=\"d-flex gap-2\">\r\n              <button \r\n                class=\"btn btn-primary flex-grow-1\" \r\n                :disabled=\"!selectedTime || booking\"\r\n                @click=\"bookAppointment\"\r\n              >\r\n                <span v-if=\"booking\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n                <i v-else class=\"fas fa-check me-2\"></i>\r\n                Confirm Booking\r\n              </button>\r\n              <button class=\"btn btn-secondary\" @click=\"selectedDoctor = null\">\r\n                <i class=\"fas fa-arrow-left me-2\"></i>\r\n                Back\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'BookAppointment',\r\n  data() {\r\n    return {\r\n      departments: [],\r\n      doctors: [],\r\n      selectedDoctor: null,\r\n      searchFilters: {\r\n        specialization: '',\r\n        name: ''\r\n      },\r\n      loading: false,\r\n      booking: false,\r\n      availableDates: [],\r\n      selectedDate: null,\r\n      availableSlots: [],\r\n      selectedTime: null,\r\n      symptoms: '',\r\n      bookedSlots: {}\r\n    }\r\n  },\r\n  created() {\r\n    this.fetchDepartments()\r\n    \r\n    // Check URL params\r\n    const specialization = this.$route.query.specialization\r\n    if (specialization) {\r\n      this.searchFilters.specialization = specialization\r\n      this.searchDoctors()\r\n    }\r\n  },\r\n  methods: {\r\n    async fetchDepartments() {\r\n      try {\r\n        const response = await this.$api.getDepartments()\r\n        this.departments = response.data\r\n      } catch (error) {\r\n        console.error('Error fetching departments:', error)\r\n      }\r\n    },\r\n    \r\n    async searchDoctors() {\r\n      this.loading = true\r\n      try {\r\n        const response = await this.$api.searchDoctors(\r\n          this.searchFilters.specialization,\r\n          this.searchFilters.name\r\n        )\r\n        this.doctors = response.data\r\n      } catch (error) {\r\n        console.error('Error searching doctors:', error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    \r\n    async selectDoctor(doctor) {\r\n      this.selectedDoctor = doctor\r\n      await this.fetchAvailability()\r\n      this.generateAvailableDates()\r\n    },\r\n    \r\n    async fetchAvailability() {\r\n      try {\r\n        const response = await this.$api.getDoctorAvailability(this.selectedDoctor.id)\r\n        this.bookedSlots = response.data.booked_slots || {}\r\n        \r\n        // Generate next 7 days\r\n        this.generateAvailableDates()\r\n        \r\n      } catch (error) {\r\n        console.error('Error fetching availability:', error)\r\n      }\r\n    },\r\n    \r\n    generateAvailableDates() {\r\n      const dates = []\r\n      const today = new Date()\r\n      \r\n      for (let i = 0; i < 7; i++) {\r\n        const date = new Date(today)\r\n        date.setDate(today.getDate() + i)\r\n        const dateStr = date.toISOString().split('T')[0]\r\n        dates.push(dateStr)\r\n      }\r\n      \r\n      this.availableDates = dates\r\n    },\r\n    \r\n    selectDate(date) {\r\n      this.selectedDate = date\r\n      this.selectedTime = null\r\n      \r\n      // Get available slots for this date\r\n      const dayName = new Date(date).toLocaleDateString('en-US', { weekday: 'long' }).toLowerCase()\r\n      const doctorAvailability = this.selectedDoctor.availability || {}\r\n      \r\n      // Get doctor's available slots for this day\r\n      const availableForDay = doctorAvailability[dayName] || []\r\n      \r\n      // Remove booked slots\r\n      const bookedForDate = this.bookedSlots[date] || []\r\n      this.availableSlots = availableForDay.filter(slot => !bookedForDate.includes(slot))\r\n    },\r\n    \r\n    selectTime(time) {\r\n      this.selectedTime = time\r\n    },\r\n    \r\n    async bookAppointment() {\r\n      this.booking = true\r\n      try {\r\n        await this.$api.bookAppointment({\r\n          doctor_id: this.selectedDoctor.id,\r\n          date: this.selectedDate,\r\n          time: this.selectedTime,\r\n          symptoms: this.symptoms\r\n        })\r\n        \r\n        alert('Appointment booked successfully!')\r\n        this.$router.push('/patient/dashboard')\r\n        \r\n      } catch (error) {\r\n        alert(error.response?.data?.error || 'Error booking appointment')\r\n      } finally {\r\n        this.booking = false\r\n      }\r\n    },\r\n    \r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString('en-US', { \r\n        weekday: 'short', \r\n        month: 'short', \r\n        day: 'numeric' \r\n      })\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AAqNA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,WAAA;MACAC,OAAA;MACAC,cAAA;MACAC,aAAA;QACAC,cAAA;QACAN,IAAA;MACA;MACAO,OAAA;MACAC,OAAA;MACAC,cAAA;MACAC,YAAA;MACAC,cAAA;MACAC,YAAA;MACAC,QAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,gBAAA;;IAEA;IACA,MAAAV,cAAA,QAAAW,MAAA,CAAAC,KAAA,CAAAZ,cAAA;IACA,IAAAA,cAAA;MACA,KAAAD,aAAA,CAAAC,cAAA,GAAAA,cAAA;MACA,KAAAa,aAAA;IA