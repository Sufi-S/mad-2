{"ast":null,"code":"export default {\n  name: 'TreatmentForm',\n  data() {\n    return {\n      appointmentId: null,\n      appointment: {},\n      treatment: {\n        diagnosis: '',\n        prescription: '',\n        notes: '',\n        next_visit_date: ''\n      },\n      patientHistory: [],\n      saving: false,\n      minNextVisitDate: new Date().toISOString().split('T')[0]\n    };\n  },\n  created() {\n    this.appointmentId = this.$route.params.appointmentId;\n    this.fetchAppointment();\n    this.fetchPatientHistory();\n  },\n  methods: {\n    async fetchAppointment() {\n      try {\n        // Get appointment details from the appointments list\n        const response = await this.$api.getDoctorAppointments('booked');\n        this.appointment = response.data.find(apt => apt.id == this.appointmentId) || {};\n        if (!this.appointment.id) {\n          alert('Appointment not found');\n          this.goBack();\n        }\n      } catch (error) {\n        console.error('Error fetching appointment:', error);\n      }\n    },\n    async fetchPatientHistory() {\n      if (!this.appointment.patient_id) return;\n      try {\n        const response = await this.$api.getPatientHistory(this.appointment.patient_id);\n        this.patientHistory = response.data.treatments || [];\n      } catch (error) {\n        console.error('Error fetching patient history:', error);\n      }\n    },\n    async saveTreatment() {\n      this.saving = true;\n      try {\n        await this.$api.saveTreatment(this.appointmentId, this.treatment);\n\n        // Update appointment status\n        await this.$api.updateAppointmentStatus(this.appointmentId, 'completed');\n        alert('Treatment saved successfully!');\n        this.$router.push('/doctor/dashboard');\n      } catch (error) {\n        alert(error.response?.data?.error || 'Error saving treatment');\n      } finally {\n        this.saving = false;\n      }\n    },\n    goBack() {\n      this.$router.push('/doctor/dashboard');\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    }\n  }\n};","map":{"version":3,"names":["name","data","appointmentId","appointment","treatment","diagnosis","prescription","notes","next_visit_date","patientHistory","saving","minNextVisitDate","Date","toISOString","split","created","$route","params","fetchAppointment","fetchPatientHistory","methods","response","$api","getDoctorAppointments","find","apt","id","alert","goBack","error","console","patient_id","getPatientHistory","treatments","saveTreatment","updateAppointmentStatus","$router","push","formatDate","date","toLocaleDateString"],"sources":["src/components/doctor/TreatmentForm.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <div class=\"row justify-content-center\">\r\n      <div class=\"col-md-8\">\r\n        <div class=\"card\">\r\n          <div class=\"card-header\">\r\n            <h4 class=\"mb-0\">\r\n              <i class=\"fas fa-stethoscope me-2\"></i>\r\n              Treatment Form\r\n            </h4>\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <!-- Appointment Info -->\r\n            <div class=\"mb-4 p-3 bg-dark rounded\">\r\n              <h6 class=\"text-white-50 mb-3\">Appointment Details</h6>\r\n              <div class=\"row\">\r\n                <div class=\"col-md-6\">\r\n                  <p class=\"mb-1\">\r\n                    <strong>Patient:</strong> {{ appointment.patient_name }}\r\n                  </p>\r\n                  <p class=\"mb-1\">\r\n                    <strong>Date:</strong> {{ formatDate(appointment.appointment_date) }}\r\n                  </p>\r\n                </div>\r\n                <div class=\"col-md-6\">\r\n                  <p class=\"mb-1\">\r\n                    <strong>Time:</strong> {{ appointment.appointment_time }}\r\n                  </p>\r\n                  <p class=\"mb-1\">\r\n                    <strong>Symptoms:</strong> {{ appointment.symptoms || 'N/A' }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Treatment Form -->\r\n            <form @submit.prevent=\"saveTreatment\">\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">\r\n                  <i class=\"fas fa-diagnoses me-2\"></i>\r\n                  Diagnosis *\r\n                </label>\r\n                <textarea \r\n                  class=\"form-control\" \r\n                  rows=\"3\" \r\n                  v-model=\"treatment.diagnosis\"\r\n                  required\r\n                  placeholder=\"Enter diagnosis\"\r\n                ></textarea>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">\r\n                  <i class=\"fas fa-prescription me-2\"></i>\r\n                  Prescription\r\n                </label>\r\n                <textarea \r\n                  class=\"form-control\" \r\n                  rows=\"3\" \r\n                  v-model=\"treatment.prescription\"\r\n                  placeholder=\"Enter prescription\"\r\n                ></textarea>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-3\">\r\n                <label class=\"form-label\">\r\n                  <i class=\"fas fa-notes-medical me-2\"></i>\r\n                  Additional Notes\r\n                </label>\r\n                <textarea \r\n                  class=\"form-control\" \r\n                  rows=\"2\" \r\n                  v-model=\"treatment.notes\"\r\n                  placeholder=\"Any additional notes\"\r\n                ></textarea>\r\n              </div>\r\n\r\n              <div class=\"form-group mb-4\">\r\n                <label class=\"form-label\">\r\n                  <i class=\"fas fa-calendar-check me-2\"></i>\r\n                  Next Visit Date\r\n                </label>\r\n                <input \r\n                  type=\"date\" \r\n                  class=\"form-control\" \r\n                  v-model=\"treatment.next_visit_date\"\r\n                  :min=\"minNextVisitDate\"\r\n                >\r\n                <small class=\"text-muted\">Leave empty if not required</small>\r\n              </div>\r\n\r\n              <div class=\"d-flex gap-2\">\r\n                <button type=\"submit\" class=\"btn btn-primary flex-grow-1\" :disabled=\"saving\">\r\n                  <span v-if=\"saving\" class=\"spinner-border spinner-border-sm me-2\"></span>\r\n                  <i v-else class=\"fas fa-save me-2\"></i>\r\n                  {{ saving ? 'Saving...' : 'Save Treatment' }}\r\n                </button>\r\n                <button type=\"button\" class=\"btn btn-secondary\" @click=\"goBack\">\r\n                  <i class=\"fas fa-arrow-left me-2\"></i>\r\n                  Back\r\n                </button>\r\n              </div>\r\n            </form>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Patient History -->\r\n        <div class=\"card mt-4\" v-if=\"patientHistory.length > 0\">\r\n          <div class=\"card-header\">\r\n            <i class=\"fas fa-history me-2\"></i>\r\n            Patient History\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <div class=\"table-responsive\">\r\n              <table class=\"table table-hover\">\r\n                <thead>\r\n                  <tr>\r\n                    <th>Date</th>\r\n                    <th>Diagnosis</th>\r\n                    <th>Prescription</th>\r\n                    <th>Next Visit</th>\r\n                  </tr>\r\n                </thead>\r\n                <tbody>\r\n                  <tr v-for=\"record in patientHistory\" :key=\"record.id\">\r\n                    <td>{{ formatDate(record.created_at) }}</td>\r\n                    <td>{{ record.diagnosis }}</td>\r\n                    <td>{{ record.prescription || 'N/A' }}</td>\r\n                    <td>{{ record.next_visit_date ? formatDate(record.next_visit_date) : 'N/A' }}</td>\r\n                  </tr>\r\n                </tbody>\r\n              </table>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'TreatmentForm',\r\n  data() {\r\n    return {\r\n      appointmentId: null,\r\n      appointment: {},\r\n      treatment: {\r\n        diagnosis: '',\r\n        prescription: '',\r\n        notes: '',\r\n        next_visit_date: ''\r\n      },\r\n      patientHistory: [],\r\n      saving: false,\r\n      minNextVisitDate: new Date().toISOString().split('T')[0]\r\n    }\r\n  },\r\n  created() {\r\n    this.appointmentId = this.$route.params.appointmentId\r\n    this.fetchAppointment()\r\n    this.fetchPatientHistory()\r\n  },\r\n  methods: {\r\n    async fetchAppointment() {\r\n      try {\r\n        // Get appointment details from the appointments list\r\n        const response = await this.$api.getDoctorAppointments('booked')\r\n        this.appointment = response.data.find(apt => apt.id == this.appointmentId) || {}\r\n        \r\n        if (!this.appointment.id) {\r\n          alert('Appointment not found')\r\n          this.goBack()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching appointment:', error)\r\n      }\r\n    },\r\n    \r\n    async fetchPatientHistory() {\r\n      if (!this.appointment.patient_id) return\r\n      \r\n      try {\r\n        const response = await this.$api.getPatientHistory(this.appointment.patient_id)\r\n        this.patientHistory = response.data.treatments || []\r\n      } catch (error) {\r\n        console.error('Error fetching patient history:', error)\r\n      }\r\n    },\r\n    \r\n    async saveTreatment() {\r\n      this.saving = true\r\n      try {\r\n        await this.$api.saveTreatment(this.appointmentId, this.treatment)\r\n        \r\n        // Update appointment status\r\n        await this.$api.updateAppointmentStatus(this.appointmentId, 'completed')\r\n        \r\n        alert('Treatment saved successfully!')\r\n        this.$router.push('/doctor/dashboard')\r\n        \r\n      } catch (error) {\r\n        alert(error.response?.data?.error || 'Error saving treatment')\r\n      } finally {\r\n        this.saving = false\r\n      }\r\n    },\r\n    \r\n    goBack() {\r\n      this.$router.push('/doctor/dashboard')\r\n    },\r\n    \r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":"AA6IA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,aAAA;MACAC,WAAA;MACAC,SAAA;QACAC,SAAA;QACAC,YAAA;QACAC,KAAA;QACAC,eAAA;MACA;MACAC,cAAA;MACAC,MAAA;MACAC,gBAAA,MAAAC,IAAA,GAAAC,WAAA,GAAAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAb,aAAA,QAAAc,MAAA,CAAAC,MAAA,CAAAf,aAAA;IACA,KAAAgB,gBAAA;IACA,KAAAC,mBAAA;EACA;EACAC,OAAA;IACA,MAAAF,iBAAA;MACA;QACA;QACA,MAAAG,QAAA,cAAAC,IAAA,CAAAC,qBAAA;QACA,KAAApB,WAAA,GAAAkB,QAAA,CAAApB,IAAA,CAAAuB,IAAA,CAAAC,GAAA,IAAAA,GAAA,CAAAC,EAAA,SAAAxB,aAAA;QAEA,UAAAC,WAAA,CAAAuB,EAAA;UACAC,KAAA;UACA,KAAAC,MAAA;QACA;MACA,SAAAC,KAAA;QACAC,OAAA,CAAAD,KAAA,gCAAAA,KAAA;MACA;IACA;IAEA,MAAAV,oBAAA;MACA,UAAAhB,WAAA,CAAA4B,UAAA;MAEA;QACA,MAAAV,QAAA,cAAAC,IAAA,CAAAU,iBAAA,MAAA7B,WAAA,CAAA4B,UAAA;QACA,KAAAtB,cAAA,GAAAY,QAAA,CAAApB,IAAA,CAAAgC,UAAA;MACA,SAAAJ,KAAA;QACAC,OAAA,CAAAD,KAAA,oCAAAA,KAAA;MACA;IACA;IAEA,MAAAK,cAAA;MACA,KAAAxB,MAAA;MACA;QACA,WAAAY,IAAA,CAAAY,aAAA,MAAAhC,aAAA,OAAAE,SAAA;;QAEA;QACA,WAAAkB,IAAA,CAAAa,uBAAA,MAAAjC,aAAA;QAEAyB,KAAA;QACA,KAAAS,OAAA,CAAAC,IAAA;MAEA,SAAAR,KAAA;QACAF,KAAA,CAAAE,KAAA,CAAAR,QAAA,EAAApB,IAAA,EAAA4B,KAAA;MACA;QACA,KAAAnB,MAAA;MACA;IACA;IAEAkB,OAAA;MACA,KAAAQ,OAAA,CAAAC,IAAA;IACA;IAEAC,WAAAC,IAAA;MACA,WAAA3B,IAAA,CAAA2B,IAAA,EAAAC,kBAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}